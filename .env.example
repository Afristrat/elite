# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Email — Resend
RESEND_API_KEY=re_your_resend_key

# WhatsApp — Evolution API (instance déjà configurée)
EVOLUTION_API_URL=http://your-evolution-api-url
EVOLUTION_API_KEY=your_evolution_api_key
EVOLUTION_INSTANCE=your_instance_name

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# CRON (générer avec: openssl rand -hex 32)
CRON_SECRET=your_cron_secret_here

# IA — Anthropic Claude (prioritaire) + Kimi (fallback)
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here
# KIMI_API_KEY=sk-your_kimi_key_here

# Backup base de données
DATABASE_BACKUP_URL=postgresql://postgres:password@localhost:5432/postgres
# BACKUP_GPG_PASSPHRASE=optional_passphrase_for_encrypted_backups

# Limites
MAX_MEMBERS=50
